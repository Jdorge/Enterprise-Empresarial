# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=enterprise_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# N8N CONFIGURATION
# ============================================
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY

# ============================================
# GRAFANA CONFIGURATION
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_URL=http://localhost:3000

# ============================================
# AI AGENTS - LLM API KEYS
# ============================================
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GLM4_API_KEY=...
GOOGLE_API_KEY=...

# ============================================
# AI AGENTS - MCP SERVER
# ============================================
MCP_PORT=8080
MCP_LOG_LEVEL=info

# ============================================
# AI AGENTS - TEMPORAL
# ============================================
TEMPORAL_NAMESPACE=enterprise-workflows
TEMPORAL_TASK_QUEUE=ai-agents
TEMPORAL_RETENTION_DAYS=30

# ============================================
# AI AGENTS - E2B SANDBOX
# ============================================
E2B_API_KEY=...
E2B_TIMEOUT_SECONDS=300

# ============================================
# AI AGENTS - CONFIGURATION
# ============================================
AGENT_LOG_LEVEL=info
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
AGENT_COST_THRESHOLD_USD=10.0

# ============================================
# RAG - QDRANT
# ============================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=...
QDRANT_COLLECTION=enterprise_knowledge

# ============================================
# INTEGRATIONS
# ============================================
# Notion
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# HubSpot
HUBSPOT_API_KEY=...

# ============================================
# BUSINESS CONFIGURATION
# ============================================
COMPANY_NAME=Enterprise Empresarial
COMPANY_DOMAIN=enterprise.com.br
SUPPORT_EMAIL=support@enterprise.com.br
DEFAULT_TIMEZONE=America/Sao_Paulo

# ============================================
# SECURITY
# ============================================
JWT_SECRET=CHANGE_ME_JWT_SECRET_KEY
API_RATE_LIMIT=100
CORS_ORIGINS=http://localhost:3000,http://localhost:5678

# ============================================
# MONITORING
# ============================================
PROMETHEUS_RETENTION_DAYS=30
ENABLE_METRICS=true
ENABLE_TRACING=true
