# ============================================================
# NEXUS ENTERPRISE V2 - ENVIRONMENT VARIABLES
# ============================================================
# 
# IMPORTANTE: 
# 1. Copie este arquivo para .env.local
# 2. Preencha TODAS as variáveis obrigatórias
# 3. NUNCA commite .env.local no Git!
#
# ============================================================

# ============ OpenRouter (Backend Principal) ============
# Obtenha sua chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ============ APIs Complementares (Opcional) ============
PERPLEXITY_API_KEY=

# ============ Database ============
POSTGRES_USER=nexus
POSTGRES_PASSWORD=
POSTGRES_DB=nexus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============ Temporal ============
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default

# ============ Qdrant Vector DB ============
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ============ n8n Automation ============
N8N_WEBHOOK_URL=http://n8n:5678/webhook
N8N_API_KEY=
N8N_PASSWORD=

# ============ Monitoring ============
GRAFANA_PASSWORD=
PROMETHEUS_PORT=9090

# ============ Security ============
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
ENCRYPTION_KEY=

# ============ Application ============
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_WORKERS=4

# ============ Rate Limiting ============
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ============ Cost Control ============
MAX_DAILY_COST_USD=100
ALERT_THRESHOLD_USD=50
